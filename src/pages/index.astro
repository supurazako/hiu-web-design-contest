---
import "leaflet/dist/leaflet.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import SceneSplit from "../components/SceneSplit.astro";
import TimeToggle from "../components/TimeToggle.astro";
import mapPageScript from "../scripts/map-page.ts?url";
import { themeByMode, uiCopy } from "../data/site";
import { spots } from "../data/spots";

const locale = "ja";
const initialMode = "day";
const ui = uiCopy[locale];
---

<BaseLayout title={`${ui.siteTitle} | ${ui.siteTagline}`} description={ui.landingLead}>
  <main class="page-shell landing-shell theme-day">
    <section class="hero">
      <div class={`map-shell hero__map-background ${themeByMode[initialMode].className}`} data-map-shell>
        <div id="map" class="map-canvas hero__map-canvas" aria-label={ui.mapPageTitle}></div>
        <canvas class="map-scratch-surface" data-scratch-surface hidden aria-hidden="true"></canvas>

        <div class="map-overlay">
          <div class="map-compare" data-compare-overlay hidden>
            <div class="map-compare__divider" data-split-divider>
              <div class="map-compare__line" aria-hidden="true"></div>
              <button
                class="map-compare__handle"
                type="button"
                data-split-handle
                aria-label={ui.compareHandleLabel}
                aria-orientation="horizontal"
                aria-valuemin="10"
                aria-valuemax="90"
                aria-valuenow="50"
                aria-valuetext="50%"
                role="slider"
              >
                <span aria-hidden="true">↔</span>
              </button>
            </div>
          </div>

          <div class="map-magnifier" data-magnifier-overlay hidden aria-hidden="true"></div>

          <div class="map-clock" data-clock-panel hidden>
            <button
              class="map-clock__dial"
              type="button"
              data-clock-dial
              aria-label={ui.clockDialLabel}
              aria-valuemin="0"
              aria-valuemax="24"
              aria-valuenow="12"
              aria-valuetext="12:00"
              role="slider"
            >
              <span class="map-clock__hand" data-clock-hand aria-hidden="true"></span>
              <span class="map-clock__center" aria-hidden="true"></span>
            </button>
            <span class="map-clock__time" data-clock-time>12:00</span>
          </div>

          <div class="map-back">
            <button class="map-toolbar__button" type="button" data-back-home-link aria-label={ui.backHome}>
              <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#1f1f1f"><path d="m313-440 224 224-57 56-320-320 320-320 57 56-224 224h487v80H313Z"/></svg>
            </button>
          </div>

          <div class="map-language">
            <button
              class="map-toolbar__button"
              type="button"
              data-language-menu-trigger
              aria-haspopup="menu"
              aria-expanded="false"
              aria-label={ui.languageLabel}
            >
              <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" aria-hidden="true">
                <path d="m326-240-30-48q80-8 125-43t45-90q0-30-20.5-55T392-512q-23 57-54.5 102T268-332q3 12 6.5 24t7.5 24l-50 15q-3-10-5-17.5t-4-13.5q-26 14-49 21.5t-45 7.5q-32 0-52-21t-20-56q0-53 40-105t103-82q1-19 2-37.5t3-37.5q-28 1-59-.5T79-615l-1-53q26 5 56 6.5t77 1.5q2-18 4.5-35.5t.5-35.5l60 1q-7 17-10 34.5t-6 34.5q58-3 107-9t92-16l1 52q-53 8-103.5 13.5T255-612q-2 14-2.5 29t-2.5 29q28-8 54.5-11t52.5-1q3-10 4.5-20t2.5-20l57 14q-3 8-6.5 16t-6.5 19q51 14 81.5 52t30.5 85q0 70-51.5 117.5T326-240Zm-188-85q17 0 35-7t38-21q-7-38-10-69t-3-59q-38 24-63 59t-25 66q0 13 8.5 22t19.5 9Zm118-65q29-28 50.5-60.5T342-520q-23 0-46.5 4T248-504q-2 26 .5 54t7.5 60Zm446 56q28 0 54.5-13t48.5-37v-106q-23 3-42.5 7t-36.5 9q-45 14-67.5 35T636-390q0 26 18 41t48 15Zm-23 68q-57 0-90-32.5T556-387q0-52 33-85t106-53q23-6 50.5-11t59.5-9q-2-47-22-68.5T721-635q-26 0-51.5 9.5T604-592l-32-56q33-25 77.5-40.5T740-704q71 0 108 44t37 128v257h-67l-6-45q-28 25-61.5 39.5T679-266Z"/>
              </svg>
            </button>

            <div class="map-language__menu" data-language-menu role="menu" aria-label={ui.languageLabel} hidden>
              <button class="map-language__option is-active" type="button" data-language-option data-locale="ja" role="menuitem">
                JP
              </button>
              <button class="map-language__option" type="button" data-language-option data-locale="en" role="menuitem">
                EN
              </button>
            </div>
          </div>

          <div class="map-control-cluster">
            <div class="map-zoom-stack" role="group" aria-label={ui.zoomControlsLabel} data-zoom-controls>
              <div class="map-zoom-stack__section">
                <button class="map-toolbar__button map-toolbar__button--stacked" type="button" data-zoom-in aria-label={ui.zoomInLabel} title={ui.zoomInLabel}>
                  <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" aria-hidden="true"><path d="M440-440H200v-80h240v-240h80v240h240v80H520v240h-80v-240Z"/></svg>
                </button>
              </div>
              <div class="map-zoom-stack__section">
                <button class="map-toolbar__button map-toolbar__button--stacked" type="button" data-zoom-out aria-label={ui.zoomOutLabel} title={ui.zoomOutLabel}>
                  <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" aria-hidden="true"><path d="M200-440v-80h560v80H200Z"/></svg>
                </button>
              </div>
            </div>
            <div class="map-control-stack" data-control-shell>
            <div class="map-control-stack__section map-control-stack__section--mode">
              <div class="map-mode-switch" role="group" aria-label={ui.displayModeLabel} data-display-mode-group>
                <div class="map-mode-switch__single-group is-expanded" data-single-group>
                  <button class="map-mode-switch__button is-active" type="button" data-display-mode="single" aria-label={ui.singleModeLabel} title={ui.singleModeLabel}>
                    <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" aria-hidden="true"><path d="M480-118 120-398l66-50 294 228 294-228 66 50-360 280Zm0-202L120-600l360-280 360 280-360 280Zm0-280Zm0 178 230-178-230-178-230 178 230 178Z"/></svg>
                  </button>
                  <div class="map-time-toggle" data-time-toggle-group>
                    <TimeToggle mode={initialMode} ui={ui} />
                  </div>
                </div>
                <button class="map-mode-switch__button" type="button" data-display-mode="compare" aria-label={ui.compareModeLabel} title={ui.compareModeLabel}>
                  <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" aria-hidden="true"><path d="M200-160q-33 0-56.5-23.5T120-240v-480q0-33 23.5-56.5T200-800h160v80H200v480h160v80H200Zm240 80v-800h80v80h240q33 0 56.5 23.5T840-720v480q0 33-23.5 56.5T760-160H520v80h-80Zm80-160h240v-480H520v480Zm-320 0v-480 480Zm560 0v-480 480Z"/></svg>
                </button>
                <button class="map-mode-switch__button" type="button" data-display-mode="magnifier" aria-label={ui.magnifierModeLabel} title={ui.magnifierModeLabel}>
                  <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" aria-hidden="true"><path d="M784-120 532-372q-30 24-69 38t-83 14q-109 0-184.5-75.5T120-580q0-109 75.5-184.5T380-840q109 0 184.5 75.5T640-580q0 44-14 83t-38 69l252 252-56 56ZM380-400q75 0 127.5-52.5T560-580q0-75-52.5-127.5T380-760q-75 0-127.5 52.5T200-580q0 75 52.5 127.5T380-400Z"/></svg>
                </button>
                <button class="map-mode-switch__button" type="button" data-display-mode="clock" aria-label={ui.clockModeLabel} title={ui.clockModeLabel}>
                  <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" aria-hidden="true"><path d="M520-494v-206h-80v240l200 120 40-68-160-86ZM480-80q-83 0-156-31.5T197-197q-54-54-85.5-127T80-480q0-83 31.5-156T197-763q54-54 127-85.5T480-880q83 0 156 31.5T763-763q54 54 85.5 127T880-480q0 83-31.5 156T763-197q-54 54-127 85.5T480-80Zm0-80q134 0 227-93t93-227q0-134-93-227t-227-93q-134 0-227 93t-93 227q0 134 93 227t227 93Zm0-320Z"/></svg>
                </button>
                <div class="map-mode-switch__scratch-group" data-scratch-group>
                  <button class="map-mode-switch__button" type="button" data-display-mode="scratch" aria-label={ui.scratchModeLabel} title={ui.scratchModeLabel}>
                    <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#1f1f1f" aria-hidden="true"><path d="M80-80v-60h81q-59-72-90-159T40-480q0-94 31-181t90-159H80v-60h200v200h-60v-116q-58 66-89 147t-31 169q0 88 31 169t89 147v-116h60v200H80Zm578-47q-23 8-46.5 7.5T566-131L304-253l18-40q10-20 28-32.5t40-14.5l68-5-112-307q-6-16 1-30.5t23-20.5q16-6 30.5 1t20.5 23l148 407-100 7 131 61q7 3 15 3.5t15-1.5l157-57q31-11 45-41.5t3-61.5l-55-150q-6-16 1-30.5t23-20.5q16-6 30.5 1t20.5 23l55 150q23 63-4.5 122.5T815-184l-157 57Zm-90-265-54-151q-6-16 1-30.5t23-20.5q16-6 30.5 1t20.5 23l55 150-76 28Zm113-41-41-113q-6-16 1-30.5t23-20.5q16-6 30.5 1t20.5 23l41 112-75 28Zm8 88Z"/></svg>
                  </button>
                  <button class="map-scratch-reset" type="button" data-scratch-reset aria-label={ui.scratchResetLabel} title={ui.scratchResetLabel} aria-hidden="true" tabindex="-1">
                    <svg xmlns="http://www.w3.org/2000/svg" height="24px" viewBox="0 -960 960 960" width="24px" fill="#1f1f1f" aria-hidden="true"><path d="M480-160q-134 0-227-93t-93-227q0-134 93-227t227-93q69 0 132 28.5T720-690v-110h80v280H520v-80h168q-32-56-87.5-88T480-720q-100 0-170 70t-70 170q0 100 70 170t170 70q77 0 139-44t87-116h84q-28 106-114 173t-196 67Z"/></svg>
                  </button>
                </div>
              </div>
            </div>
          </div>
          </div>

          <div class="sheet-host sheet-host--floating">
            <section class="spot-card is-empty-sheet" id="spot-card" data-spot-card hidden>
              <div class="spot-card__visual placeholder-river" data-spot-visual aria-hidden="true" hidden>
                <div class="spot-card__visual-overlay"></div>
              </div>
              <div class="spot-card__body">
                <div class="spot-card__meta" data-spot-meta hidden>
                  <span class="spot-card__pill" data-spot-category></span>
                  <span class="spot-card__pill" data-spot-route></span>
                </div>
                <h2 data-spot-title hidden></h2>
                <p data-spot-description hidden></p>
                <p class="spot-card__detail-label" data-spot-detail-label hidden></p>
                <div data-spot-empty>
                  <p class="spot-card__empty-title" data-spot-empty-title>{ui.cardEmptyTitle}</p>
                  <p data-spot-empty-hint>{ui.cardEmptyHint}</p>
                </div>
              </div>
            </section>
          </div>

          <div class="map-attribution">
            <span>{ui.mapDataAttribution}</span>
            <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noreferrer">ODbL</a>
          </div>
        </div>
      </div>
      <div class="hero__content">
        <p class="eyebrow">{ui.landingEyebrow}</p>
        <h1>
          <span>時間で表情が変わる</span>
          <span>温泉街を</span>
          <span>ひとつの地図で。</span>
        </h1>
        <p class="lead">{ui.landingLead}</p>
        <div class="hero__actions">
          <a class="button button--primary" href="#map" data-open-map>{ui.landingPrimaryCta}</a>
        </div>
      </div>
    </section>

    <section class="content-block" id="contrast">
      <div class="section-heading">
        <p class="eyebrow">{ui.exploreLabel}</p>
        <h2>{ui.conceptTitle}</h2>
        <p>{ui.conceptBody}</p>
      </div>
      <SceneSplit
        dayLabel={ui.dayLabel}
        nightLabel={ui.nightLabel}
        dayMood={ui.dayMood}
        nightMood={ui.nightMood}
      />
    </section>

    <section class="content-block">
      <div class="section-heading">
        <p class="eyebrow">{ui.sectionsTitle}</p>
        <h2>{ui.mapIntroTitle}</h2>
      </div>
      <div class="steps-grid">
        {ui.steps.map((step, index) => (
          <article class="step-card">
            <span>{String(index + 1).padStart(2, "0")}</span>
            <p>{step}</p>
          </article>
        ))}
      </div>
    </section>
  </main>

  <script id="spots-data" type="application/json" set:html={JSON.stringify(spots)}></script>
  <script id="ui-data" type="application/json" set:html={JSON.stringify(uiCopy)}></script>
  <script id="theme-data" type="application/json" set:html={JSON.stringify(themeByMode)}></script>
  <script type="module" src={mapPageScript}></script>
</BaseLayout>
