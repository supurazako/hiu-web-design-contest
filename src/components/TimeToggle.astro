---
type Props = {
  mode: "day" | "night";
  ui: {
    dayLabel: string;
    nightLabel: string;
    timeLabel: string;
  };
};

const { mode, ui } = Astro.props;
---

<div class="segmented-control" role="group" aria-label={ui.timeLabel}>
  <button class:list={["segmented-control__button", mode === "day" && "is-active"]} data-time-mode="day" type="button">
    {ui.dayLabel}
  </button>
  <button class:list={["segmented-control__button", mode === "night" && "is-active"]} data-time-mode="night" type="button">
    {ui.nightLabel}
  </button>
</div>
