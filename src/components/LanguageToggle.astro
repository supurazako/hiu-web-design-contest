---
import type { Locale } from "../data/site";

type Props = {
  locale: Locale;
  ui: {
    languageLabel: string;
  };
};

const { locale, ui } = Astro.props;
---

<div class="segmented-control" role="group" aria-label={ui.languageLabel}>
  <button class:list={["segmented-control__button", locale === "ja" && "is-active"]} data-locale="ja" type="button">
    JP
  </button>
  <button class:list={["segmented-control__button", locale === "en" && "is-active"]} data-locale="en" type="button">
    EN
  </button>
</div>
